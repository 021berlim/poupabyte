OPENROUTER_API_KEY=replace-with-your-openrouter-key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODEL=openai/gpt-oss-20b:free
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Na Vercel, use a URL de produção (ex.: https://seu-app.vercel.app). VERCEL_URL é preenchida automaticamente no deploy.

# Provedor ativo da P.E.N.N.Y quando ROUTING_ENABLED=false: openrouter (padrão) | gemini | huggingface
AI_PROVIDER=openrouter

# Roteamento inteligente da P.E.N.N.Y (desativado por padrão para preservar o comportamento atual)
ROUTING_ENABLED=false
ROUTING_CROSS_PROVIDER_FALLBACK=true
SIMPLE_PROVIDER=openrouter
MEDIUM_PROVIDER=openrouter
COMPLEX_PROVIDER=openrouter
AI_TIMEOUT_MS=60000
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=8192
AI_RATE_LIMIT_PER_MINUTE=60

# Google AI Studio (Gemini) — provedor secundário em standby
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-pro
GEMINI_TIMEOUT_MS=60000

# Hugging Face Inference — provedor terciário em standby
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct-1M
HUGGINGFACE_FALLBACK_MODEL=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_TIMEOUT_MS=60000
HUGGINGFACE_API_BASE=https://router.huggingface.co/v1

# Opcional para APK/Capacitor: URL HTTPS do backend Next que mantÃ©m /api/assistant e /api/import-statement.
# Se vazio, o app usa chamadas relativas como no web.
NEXT_PUBLIC_API_BASE_URL=

# Opcional: interpretador externo para bancos sem parser nativo.
STATEMENT_AI_ENDPOINT=
STATEMENT_AI_TOKEN=
